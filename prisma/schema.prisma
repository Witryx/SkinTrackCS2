generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  steamId        String?  @unique
  email          String?  @unique
  emailEncrypted String?  @db.Text
  emailHash      String?  @unique
  name           String?
  avatarUrl      String?
  createdAt      DateTime @default(now())

  favorites     Favorite[]
  notifications Notification[]
}

model Skin {
  id             Int      @id @default(autoincrement())
  marketHashName String   @unique
  weapon         String
  skin           String
  wear           String?
  rarity         String
  minFloat       Float?
  maxFloat       Float?
  price          Float?
  medianPrice    Float?
  suggestedPrice Float?
  quantity       Int?
  volume7d       Float?
  median7d       Float?
  currency       String   @default("EUR")
  itemPage       String?
  marketPage     String?
  imageUrl       String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  priceHistory  PriceHistory[]
  favorites     Favorite[]
  notifications Notification[]

  @@index([weapon, skin])
  @@index([rarity])
  @@index([price])
  @@index([marketHashName])
}

model Shop {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  url       String?
  createdAt DateTime @default(now())

  priceHistory PriceHistory[]
}

model PriceHistory {
  id         Int      @id @default(autoincrement())
  skinId     Int
  shopId     Int
  currency   String
  price      Float
  capturedAt DateTime @default(now())

  skin Skin @relation(fields: [skinId], references: [id])
  shop Shop @relation(fields: [shopId], references: [id])

  @@index([skinId, capturedAt])
  @@map("PriceSnapshot")
}

model Favorite {
  userId             Int
  skinId             Int
  alertsEnabled      Boolean   @default(true)
  emailAlertsEnabled Boolean   @default(true)
  lastEmailAlertAt   DateTime?
  createdAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
  skin Skin @relation(fields: [skinId], references: [id])

  @@id([userId, skinId])
}

model Notification {
  id            Int                   @id @default(autoincrement())
  userId        Int
  skinId        Int
  type          NotificationType      @default(PRICE_CHANGE)
  title         String
  message       String                @db.Text
  previousPrice Float?
  currentPrice  Float?
  changePercent Float?
  direction     PriceChangeDirection?
  currency      String                @default("EUR")
  readAt        DateTime?
  emailedAt     DateTime?
  createdAt     DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  skin Skin @relation(fields: [skinId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([skinId, createdAt])
}

enum NotificationType {
  PRICE_CHANGE
}

enum PriceChangeDirection {
  UP
  DOWN
}
