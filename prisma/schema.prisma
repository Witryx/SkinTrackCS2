generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  steamId   String?   @unique
  email     String?   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime  @default(now())

  favorites Favorite[]
}

model Skin {
  id             Int              @id @default(autoincrement())
  marketHashName String           @unique
  weapon         String
  skin           String
  wear           String?
  rarity         String
  minFloat       Float?
  maxFloat       Float?
  price          Float?
  medianPrice    Float?
  suggestedPrice Float?
  quantity       Int?
  volume7d       Float?
  median7d       Float?
  currency       String           @default("EUR")
  itemPage       String?
  marketPage     String?
  imageUrl       String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  priceSnapshots PriceSnapshot[]
  favorites      Favorite[]

  @@index([weapon, skin])
  @@index([rarity])
  @@index([price])
  @@index([marketHashName])
}

model Shop {
  id        Int             @id @default(autoincrement())
  name      String          @unique
  url       String?
  createdAt DateTime        @default(now())

  priceSnapshots PriceSnapshot[]
}

model PriceSnapshot {
  id         Int      @id @default(autoincrement())
  skinId     Int
  shopId     Int
  currency   String
  price      Float
  capturedAt DateTime @default(now())

  skin Skin @relation(fields: [skinId], references: [id])
  shop Shop @relation(fields: [shopId], references: [id])

  @@index([skinId, capturedAt])
}

model Favorite {
  userId    Int
  skinId    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  skin Skin @relation(fields: [skinId], references: [id])

  @@id([userId, skinId])
}
