DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"
NEXT_PUBLIC_SITE_URL="https://your-project.vercel.app"

# Required for Steam login/profile data.
STEAM_API_KEY=""

# Used by Vercel Cron and manual cron calls. Use one long random value.
CRON_SECRET=""

# Required only when e-mail alerts should actually send.
RESEND_API_KEY=""
EMAIL_FROM="SkinTrack <alerts@your-domain.com>"

# Optional market integrations.
CSFLOAT_API_KEY=""
CSFLOAT_INSPECT_API=""
DMARKET_PUBLIC_KEY=""
DMARKET_SECRET_KEY=""
